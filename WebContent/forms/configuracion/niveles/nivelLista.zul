<?page title="Lista de niveles" contentType="text/html;charset=UTF-8"?>

<zk>
	<window apply="org.zkoss.bind.BindComposer" border="none"
		viewModel="@id('vm') @init('ec.com.hotel.controlador.configuracion.NivelLista')"
		hflex="1" vflex="1">
		<vlayout vflex="1">
			<div style="margin-top:10px">
				<image src="/imagenes/ic_niveles_negro.png"
					width="30px" />
				<label value="Registro de Niveles"
					style="font-size:25px;font-weight: bold;" />
			</div>
			<separator hflex="1" style="border-color: #000000;border-width:0.1px;border-style: solid; margin-bottom:10px;" height="1px"/>
			<div hflex="1">
				<hlayout hflex="1">
					<div hflex="1">
						<button label="Registrar Nuevo nivel"
							iconSclass="z-icon-plus" onClick="@command('nuevo')" />
					</div>

					<div >
						<textbox value="@bind(vm.textoBuscar)" onOK="@command('buscar')"
							width="300px" style="text-transform:uppercase"
							placeholder="Búsqueda por tipo de documento" />
						<button iconSclass="z-icon-search"
							onClick="@command('buscar')" />
					</div>
				</hlayout>
			</div>
			<hlayout></hlayout>
			<hlayout vflex="1" hflex="1">
				<listbox id="lstNivel" model="@load(vm.listaNiveles)" autopaging="true"
					mold="paging" hflex="1" vflex="1">
					<listhead>
						<listheader label="Tipo de documentos" />
						<listheader label="Estado" width="20%" />
						<listheader label="Acción" width="20%"
							align="center" />
					</listhead>
					<template name="model">
						<listitem>
							<listcell label="@load(each.nivel)" />
							<listcell label="@load(each.estado)" />
							<listcell>
								<div align="center">
									<button label="Editar"
										iconSclass="z-icon-pencil"
										onClick="@command('editar',documento=each)" />
									<button label="Eliminar"
										iconSclass="z-icon-trash-o"
										onClick="@command('eliminar',documento=each)" />
								</div>
							</listcell>
						</listitem>
					</template>
				</listbox>
			</hlayout>
		</vlayout>
	</window>
</zk>
